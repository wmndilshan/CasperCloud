# Local builds need Go 1.23+ (see go.mod). Install libvirt-dev for CGO. GitHub Actions uses the latest stable Go.
HTTP_ADDR=:8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/caspercloud?sslmode=disable
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
JWT_SECRET=change-me
LIBVIRT_URI=qemu:///system
LIBVIRT_NETWORK=default
VM_DEFAULT_RAM_MB=2048
VM_DEFAULT_VCPU=2
VM_STORAGE_DIR=/var/lib/libvirt/images
VM_INSTANCES_DIR=/var/lib/caspercloud/instances
QEMU_IMG_PATH=qemu-img
CLOUD_LOCALDS_PATH=
GENISOIMAGE_PATH=
